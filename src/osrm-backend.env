# /etc/sysconfig/osrm-backend
# OSRM Backend Runtime Configuration

# Dataset name (matches your .osrm files prefix)
DATASET_NAME=berlin

# Routing algorithm: MLD (recommended) or CH
ALGORITHM=MLD

# Network binding
BIND_IP=127.0.0.1
BIND_PORT=5000

# Performance tuning
THREADS=4
MAX_VIA=50
MAX_TABLE=100
MAX_NEAREST=100

# Additional osrm-routed flags (space-separated)
EXTRA_ARGS="--compression=true --disable-feature-layers=false"
