@@ -57,6 +61,19 @@
     std::vector<Value> values;
 };
 
+// Value is defined as a struct inheriting from the variant so that:
+//   1. Its forward declaration above makes Object/Array complete types.
+//   2. Object and Array are complete types by the time std::variant is
+//      instantiated here (they appear before this definition).
+//   3. std::visit works unchanged because the visitor dispatches through
+//      the variant base, and all existing operator()(const T&) overloads
+//      in Renderer<> continue to match.
+struct Value : std::variant<String, Number, Object, Array, True, False, Null>
+{
+    using variant::variant;
+    using variant::operator=;
+};
