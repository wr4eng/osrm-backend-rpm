+// requires all std::variant alternative types to be complete at the point
+// the variant template is instantiated; Object and Array using std::vector /
+// std::unordered_map of a *forward-declared* Value is valid because those
+// containers only need Value to be complete when their own members are
+// instantiated, which happens after the full Value definition below.
+struct Value;
 
